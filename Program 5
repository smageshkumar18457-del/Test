#include <iostream>
using namespace std;

class Vehicle {
protected:
    int speed;

public:
    void setSpeed(int s) {
        speed = s;
    }
};

class Car : public Vehicle {
public:
    void show() {
        cout << "Speed: " << speed;
    }
};

int main() {
    Car c;
    c.setSpeed(120);
    c.show();
}
