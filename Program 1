#include <iostream>
using namespace std;

class Student {
private:
    int marks;   // hidden

public:
    void setMarks(int m) {
        marks = m;
    }

    void getMarks() {
        cout << "Marks: " << marks << endl;
    }
};

int main() {
    Student s;
    s.setMarks(85);
    s.getMarks();
}
